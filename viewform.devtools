 trường",null,5,[[387038813,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eUT3.  CTCK Yuanta có vị thế và quy mô hoạt động lớn trên thị trường\u003c/b\u003e\u003c/span\u003e"]],[1824213990,"UT4. CTCK Yuanta hoạt động minh bạch và tuân thủ quy định pháp luật",null,5,[[1184420151,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eUT4. CTCK Yuanta hoạt động minh bạch và tuân thủ quy định pháp luật\u003c/b\u003e\u003c/span\u003e"]],[228606881,"Chi phí dịch vụ (CP)",null,6,null,null,null,null,null,null,null,[null,"\u003cb\u003e\u003cspan\u003eChi phí dịch vụ \u003c/span\u003e\u003cspan\u003e(CP)\u003c/span\u003e\u003c/b\u003e\u003cbr\u003e"]],[1075925291,"CP1. Chi phí dịch vụ tư vấn tại CTCK Yuanta là hợp lý",null,5,[[926559151,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eCP1. Chi phí dịch vụ tư vấn tại CTCK Yuanta là hợp lý\u003c/b\u003e\u003c/span\u003e"]],[1048507731,"CP2.  Chi phí dịch vụ tương xứng với chất lượng nhận được",null,5,[[475896920,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eCP2.  Chi phí dịch vụ tương xứng với chất lượng nhận được\u003c/b\u003e\u003c/span\u003e"]],[1807063235,"CP3. Chi phí không gây áp lực tài chính cho tôi",null,5,[[1218092709,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eCP3. Chi phí không gây áp lực tài chính cho tôi\u003c/b\u003e\u003c/span\u003e"]],[1961939101,"4. Chất lượng dịch vụ tư vấn đầu tư (CL)",null,6,null,null,null,null,null,null,null,[null,"\u003cb\u003e4. Chất lượng dịch vụ tư vấn đầu tư (CL)\u003c/b\u003e"]],[13597311,"CL1.  Khuyến nghị đầu tư có giá trị tham khảo cao",null,5,[[1133675037,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eCL1.  Khuyến 