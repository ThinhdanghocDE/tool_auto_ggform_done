useleave:xq3APb; touchstart:jJiBRc; touchmove:kZeBdd; touchend:VfAz8;focusin:MeMJlc; focusout:bkTmIf;mouseenter:SKyDAe; change:uOgbud;" role="menuitem" jsname="DITn2" tabindex="-1"><span class="VfPpkd-StrnGf-rymPhb-pZXsl"></span><span class="VfPpkd-StrnGf-rymPhb-Zmlebc-LhBDec"></span><span class=" VfPpkd-StrnGf-rymPhb-f7MjDc"><div class="foqfDc gdyQ3c"><div class="Y0xAIe BNL9Bd NpcyEe-n5T17d-Bz112c-uQPRwe-BvMwwf" aria-hidden="true">&nbsp;</div><div class="Y0xAIe ivmiLb NpcyEe-n5T17d-Bz112c-uQPRwe-AhqUyc" aria-hidden="true">&nbsp;</div><div class="Y0xAIe tDDvMb NpcyEe-n5T17d-Bz112c-uQPRwe" aria-hidden="true">&nbsp;</div></div></span><span jsname="K4r5Ff" class="VfPpkd-StrnGf-rymPhb-b9t22c">Report</span></li></ul></div></div></div></div></div><script nonce="qhCgd9AK45Q4Me0iwa_-tA">var FB_PUBLIC_LOAD_DATA_ = [null,["Chào anh/chị, tôi là Trần Quỳnh Như - nhân viên môi giới chứng khoán tại Công ty TNHH Chứng khoán Yuanta Việt Nam.\nLời đầu tiên, tôi xin gửi lời chào trân trọng và lời chúc sức khỏe đến Quý nhà đầu tư.\nVới mong muốn tìm hiểu sâu hơn về nhu cầu thị trường, từ đó không ngừng cải thiện chất lượng dịch vụ và mang lại những giá trị tư vấn sát thực nhất, tôi đang thực hiện một khảo sát ngắn về: 'Các nhân tố ảnh hưởng đến quyết định sử dụng dịch vụ tư vấn đầu tư'.\nSự tham gia và những ý kiến đóng góp khách quan từ mọi người — dù đã, đang hoặc sẽ quan tâm đến dịch vụ của Yuanta — chính là cơ sở quan trọng để chúng tôi hoàn thiện năng lực phục vụ và đóng góp tích cực hơn vào cộng đồng đầu tư.\nTrân trọng cảm ơn!",[[325461537,"THÔNG TIN CHUNG VỀ NHÀ ĐẦU TƯ",null,8,null,null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eTHÔNG TIN CHUNG VỀ NHÀ ĐẦU TƯ\u003c/b\u003e\u003c/span\u003e\u003cspan\u003e\u003c/span\u003e\u003cspan\u003e\u003c/span\u003e"]],[523957353,"Giới tính của anh/chị là gì?",null,2,[[667922728,[["Nam",null,null,null,0],["Nữ",null,null,null,0],["Khác",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003eGiới tính của anh/chị là gì?\u003c/b\u003e"]],[1534773969,"Độ tuổi của anh/ chị thuộc nhóm nào?",null,2,[[1830200648,[["Dưới 25 tuổi",null,null,null,0],["Từ 25 - 34 tuổi",null,null,null,0],["Từ 35 - 44 tuổi",null,null,null,0],["Từ 45 - 54 tuổi",null,null,null,0],["Trên 55 tuổi",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003eĐộ tuổi của anh/ chị thuộc nhóm nào?\u003c/b\u003e"]],[1802554146,"Mức thu nhập trung bình hàng tháng của anh/chị là bao nhiêu?",null,2,[[463079656,[["Dưới 10 triệu VNĐ",null,null,null,0],["10 - dưới 20 triệu VNĐ",null,null,null,0],["20 - dưới 30 triệu VNĐ",null,null,null,0],["30 - dưới 50 triệu VNĐ",null,null,null,0],["Trên 50 triệu VNĐ",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e\u003cb\u003eMức thu nhập trung bình hàng tháng của anh/chị là bao nhiêu?\u003c/b\u003e\u003c/span\u003e\u003c/p\u003e"]],[1450223240,"Anh/chị đã tham gia đầu tư chứng khoán được bao lâu?",null,2,[[2147235682,[["Chưa từng",null,null,null,0],["Dưới 1 năm",null,null,null,0],["1 năm - dưới 5 năm",null,null,null,0],["Từ 5 năm trở lên",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e\u003cb\u003eAnh/chị đã tham gia đầu tư chứng khoán được bao lâu?\u003c/b\u003e\u003c/span\u003e\u003c/p\u003e"]],[1946348184,"Giá trị danh mục đầu tư chứng khoán hiện tại của anh/chị đang sở hữu ?",null,2,[[900694859,[["Dưới 100 triệu VNĐ",null,null,null,0],["100 triệu VNĐ - dưới 500 triệu VNĐ",null,null,null,0],["500 triệu VNĐ - dưới 1 tỷ VNĐ",null,null,null,0],["Từ 1 tỷ VNĐ trở lên",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e\u003cb\u003eGiá trị danh mục đầu tư chứng khoán hiện tại của anh/chị đang sở hữu ?\u003c/b\u003e\u003c/span\u003e\u003c/p\u003e"]],[475611857,"Trình độ học vấn của anh/chị?",null,2,[[956398727,[["Phổ thông trung học/ Trung cấp",null,null,null,0],["Đại học",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e\u003cb\u003eTrình độ học vấn của anh/chị?\u003c/b\u003e\u003c/span\u003e\u003c/p\u003e"]],[1321507385,"THÔNG TIN VỀ HÀNH VI SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ CỦA NHÀ ĐẦU TƯ CÁ NHÂN",null,8,null,null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eTHÔNG TIN VỀ HÀNH VI SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ CỦA NHÀ ĐẦU TƯ CÁ NHÂN\u003c/b\u003e\u003c/span\u003e\u003cspan\u003e\u003c/span\u003e"]],[185770560,"Anh/chị đã từng sử dụng dịch vụ tư vấn đầu tư tại CTCK Yuanta chưa?",null,2,[[959643901,[["Đã từng",null,null,null,0],["Chưa",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e\u003cb\u003eAnh/chị đã từng sử dụng dịch vụ tư vấn đầu tư tại CTCK Yuanta chưa?\u003c/b\u003e\u003c/span\u003e\u003c/p\u003e"]],[1479954210,"Tần suất sử dụng dịch vụ tư vấn đầu tư? ( Nếu chưa từng sử dụng thì bỏ qua câu này)",null,2,[[1853307524,[["Rất thường xuyên",null,null,null,0],["Thường xuyên",null,null,null,0],["Bình thường",null,null,null,0],["Thỉnh thoảng",null,null,null,0],["Rất ít",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003eTần suất sử dụng dịch vụ tư vấn đầu tư? ( Nếu chưa từng sử dụng thì bỏ qua câu này)\u003c/b\u003e"]],[1201167932,"(Chọn tối đa 3 yếu tố)  Theo anh/chị, sự khác biệt giữa dịch vụ tư vấn đầu tư tại CTCK và việc tự nghiên cứu thông tin chủ yếu nằm ở yếu tố nào? ",null,4,[[1730727202,[["Độ chính xác của thông tin",null,null,null,0],["Tính chuyên môn/chuyên gia",null,null,null,0],["Mức độ cá nhân hóa theo nhu cầu",null,null,null,0],["Tốc độ cập nhật thông tin",null,null,null,0],["Khả năng sinh lợi cao hơn",null,null,null,0],["Giảm rủi ro đầu tư",null,null,null,0],["Tiết kiệm thời gian",null,null,null,0],["Không thấy khác biệt rõ rệt",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003e(Chọn tối đa 3 yếu tố)\u003c/b\u003e  \u003cspan\u003e\u003cb\u003eTheo anh/chị, sự khác biệt giữa dịch vụ tư vấn đầu tư tại CTCK và việc tự nghiên cứu thông tin chủ yếu nằm ở yếu tố nào? \u003c/b\u003e\u003c/span\u003e"]],[793050180,"Theo anh/chị, dịch vụ tư vấn đầu tư tại CTCK có khác biệt so với việc tự nghiên cứu thông tin (từ mạng xã hội, diễn đàn, báo chí tài chính,...)?",null,2,[[1473697678,[["Khác biệt rất lớn ( tốt hơn)",null,null,null,0],["Khác biệt khá lớn",null,null,null,0],["Khác biệt ít",null,null,null,0],["Không khác biệt",null,null,null,0],["Không biết",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eTheo anh/chị, dịch vụ tư vấn đầu tư tại CTCK có khác biệt so với việc tự nghiên cứu thông tin (từ mạng xã hội, diễn đàn, báo chí tài chính,...)?\u003c/b\u003e\u003c/span\u003e"]],[2118390927,"Anh/ chị chủ yếu đầu tư theo",null,2,[[85205205,[["Tự phân tích",null,null,null,0],["Kết hợp tự phân tích và tư vấn",null,null,null,0],["Phần lớn theo tư vấn",null,null,null,0],["Hoàn toàn theo tư vấn của nhân viên môi giới/ nhân viên tư vấn",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003eAnh/ chị chủ yếu đầu tư theo\u003c/b\u003e"]],[431371919,"( Chọn tối đa 3 lựa chọn)  Theo anh/chị, nhân viên tư vấn đầu tư cần phải đáp ứng những yếu tố nào sau đây? ",null,4,[[437673328,[["Kiến thức chuyên môn vững vàng về thị trường chứng khoán",null,null,null,0],["Có kinh nghiệm thực tế trong đầu tư",null,null,null,0],["Phân tích và dự báo thị trường chính xác",null,null,null,0],["Cung cấp thông tin kịp thời",null,null,null,0],["Trung thực và minh bạch",null,null,null,0],["Đặt lợi ích của khách hàng lên trên lợi ích cá nhân",null,null,null,0],["Hiểu rõ nhu cầu và khẩu vị rủi ro của khách hàng",null,null,null,0],["Có khả năng giải thích thông tin rõ ràng, dễ hiểu",null,null,null,0],["Theo sát danh mục đầu tư của khách hàng",null,null,null,0],["Có chứng chỉ hành nghề hợp pháp",null,null,null,0],["Thái độ nhiệt tình, hỗ trợ tận tâm",null,null,null,0],["Cam kết mức sinh lời cao",null,null,null,0]],1,null,null,null,null,null,0]],null,null,null,null,null,null,[null,"\u003cb\u003e( Chọn tối đa 3 lựa chọn)\u003c/b\u003e  \u003cspan\u003e\u003cb\u003eTheo anh/chị, nhân viên tư vấn đầu tư cần phải đáp ứng những yếu tố nào sau đây? \u003c/b\u003e\u003c/span\u003e"]],[955725776,"CÁC NHÂN TỐ ẢNH HƯỞNG ĐẾN QUYẾT ĐỊNH SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ","Vui lòng đánh giá mức độ đồng ý của anh/chị với các phát biểu sau: \n(1 \u003d Hoàn toàn không đồng ý, 2 \u003d Không đồng ý, 3 \u003d Trung lập, 4 \u003d Đồng ý, 5 \u003d Hoàn toàn đồng ý)",8,null,null,null,null,null,null,null,[null,"\u003cb\u003eCÁC NHÂN TỐ ẢNH HƯỞNG ĐẾN QUYẾT ĐỊNH SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ\u003c/b\u003e"],[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003eVui lòng đánh giá mức độ đồng ý của anh/chị với các phát biểu sau: \u003c/span\u003e\u003c/p\u003e\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e(1 \u003d Hoàn toàn không đồng ý, 2 \u003d Không đồng ý, 3 \u003d Trung lập, 4 \u003d Đồng ý, 5 \u003d Hoàn toàn đồng ý)\u003c/span\u003e\u003c/p\u003e"]],[712203067,"1.  Năng lực \u0026 chuyên môn của chuyên viên tư vấn (NL)",null,6,null,null,null,null,null,null,null,[null,"\u003cb\u003e1. \n\n\u003cspan\u003eNăng lực \u0026amp; chuyên môn của chuyên viên tư vấn (NL)\u003c/span\u003e\u003c/b\u003e"]],[1146673948,"NL1. Chuyên viên tư vấn có kiến thức chuyên môn vững",null,5,[[1369367013,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eNL1. Chuyên viên tư vấn có kiến thức chuyên môn vững\u003c/b\u003e\u003c/span\u003e"]],[1935914248,"NL2. Chuyên viên tư vấn được đào tạo đúng chuyên ngành tài chính/chứng khoán",null,5,[[1250875761,[["1"],["2"],["3"],["4"],["5"]],1,["","