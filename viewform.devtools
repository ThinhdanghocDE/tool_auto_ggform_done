ồng/mạng xã hội ảnh hưởng đến tôi\u003c/b\u003e\u003c/span\u003e"]],[955518031,"HV3. Tôi dễ bị ảnh hưởng bởi xu hướng đầu tư của số đông",null,5,[[1349689266,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eHV3. Tôi dễ bị ảnh hưởng bởi xu hướng đầu tư của số đông\u003c/b\u003e\u003c/span\u003e"]],[2047234828,"HV4. Tôi sợ bỏ lỡ cơ hội sinh lời (FOMO)",null,5,[[1785431672,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eHV4. Tôi sợ bỏ lỡ cơ hội sinh lời (FOMO)\u003c/b\u003e\u003c/span\u003e"]],[895244969,"HV5. Tôi thiếu tự tin khi tự ra quyết định đầu tư",null,5,[[1765843847,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eHV5. Tôi thiếu tự tin khi tự ra quyết định đầu tư\u003c/b\u003e\u003c/span\u003e"]],[61417642,"QUYẾT ĐỊNH VÀ Ý ĐỊNH SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ (QD)","Vui lòng đánh giá mức độ đồng ý của anh/chị với các phát biểu sau: \n(1 \u003d Hoàn toàn không đồng ý, 2 \u003d Không đồng ý, 3 \u003d Trung lập, 4 \u003d Đồng ý, 5 \u003d Hoàn toàn đồng ý)",8,null,null,null,null,null,null,null,[null,"\u003cb\u003eQUYẾT ĐỊNH VÀ Ý ĐỊNH SỬ DỤNG DỊCH VỤ TƯ VẤN ĐẦU TƯ (QD)\u003c/b\u003e"],[null,"\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003eVui lòng đánh giá mức độ đồng ý của anh/chị với các phát biểu sau: \u003c/span\u003e\u003c/p\u003e\u003cp dir\u003d\"ltr\"\u003e\u003cspan\u003e(1 \u003d Hoàn toàn không đồng ý, 2 \u003d Không đồng ý, 3 \u003d Trung lập, 4 \u003d Đồng ý, 5 \u003d Hoàn toàn đồng ý)\u003c/span\u003e\u003c/p\u003e"]],[1088060503,"QD1. Trong thời gian tới, tôi  có ý định sẽ sử dụng hoặc tăng cường sử dụng dịch vụ tư vấn đầu tư tại CTCK",null,5,[[719653091,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eQD1. Trong thời gian tới, tôi  có ý định sẽ sử dụng hoặc tăng cường sử dụng dịch vụ tư vấn đầu tư tại CTCK\u003c/b\u003e\u003c/span\u003e"]],[1249490928,"QD2. Tôi sẵn sàng giới thiệu dịch vụ cho người khác",null,5,[[989721069,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eQD2. Tôi sẵn sàng giới thiệu dịch vụ cho người khác\u003c/b\u003e\u003c/span\u003e"]],[919918674,"QD3. Tôi ưu tiên sử dụng dịch vụ tư vấn khi đầu tư",null,5,[[25071617,[["1"],["2"],["3"],["4"],["5"]],1,["",""]]],null,null,null,null,null,null,[null,"\u003cspan\u003e\u003cb\u003eQD3. Tôi ưu tiên sử dụng dịch vụ tư vấn khi đầu tư\u003c/b\u003e\u003c/span\u003e"]],[2108822116,"Cảm ơn anh/chị đã tham gia khảo sát! Chúc mọi người một ngày mới thật nhiều niềm vui \u003c3",null,8,null,null,null,null,null,null,null,[null,"Cảm ơn anh/chị đã tham gia khảo sát! Chúc mọi người một ngày mới thật nhiều niềm vui \u0026lt;3\u003cspan\u003e\u003c/span\u003e"]]],null,null,null,null,null,null,"Các nhân tố ảnh hưởng đến quyết định sử dụng dịch vụ tư vấn đầu tư của nhà đầu tư cá nhân tại Công ty TNHH Chứng khoán Yuanta Việt Nam",73,[null,null,null,2,null,null,1],null,null,null,null,[2],null,null,null,null,null,null,null,null,[null,"Chào anh/chị, tôi là Trần Quỳnh Như - nhân viên môi giới chứng khoán tại Công ty TNHH Chứng khoán Yuanta Việt Nam.\u003cdiv\u003e\u003cp\u003eLời đầu tiên, tôi xin gửi lời chào trân trọng và lời chúc sức khỏe đến Quý nhà đầu tư.\u003c/p\u003e\u003cp\u003eVới mong muốn tìm hiểu sâu hơn về nhu cầu thị trường, từ đó không ngừng cải thiện chất lượng dịch vụ và mang lại những giá trị tư vấn sát thực nhất, tôi đang thực hiện một khảo sát ngắn về: \u003cb\u003e'Các nhân tố ảnh hưởng đến quyết định sử dụng dịch vụ tư vấn đầu tư'\u003c/b\u003e.\u003c/p\u003e\u003cp\u003eSự tham gia và những ý kiến đóng góp khách quan từ mọi người — dù đã, đang hoặc sẽ quan tâm đến dịch vụ của Yuanta — chính là cơ sở quan trọng để chúng tôi hoàn thiện năng lực phục vụ và đóng góp tích cực hơn vào cộng đồng đầu tư.\u003c/p\u003e\u003cp\u003eTrân trọng cảm ơn!\u003c/p\u003e\u003c/div\u003e"],[null,"\u003cb\u003e\u003ci\u003eCác nhân tố ảnh hưởng đến quyết định sử dụng dịch vụ tư vấn đầu tư của nhà đầu tư cá nhân tại Công ty TNHH Chứng khoán Yuanta Việt Nam\u003c/i\u003e\u003c/b\u003e"]],"/forms","Khảo sát các nhân tố ảnh hưởng đến quyết định sử dụng dịch vụ tư vấn đầu tư của nhà đầu tư cá nhân tại Công ty Chứng khoán Yuanta\t\t\t\t\t\t",null,null,null,"4",null,0,1,null,"Học viện Ngân Hàng",1,"e/1FAIpQLSegeM6Ymz07IMSY3-354fgX4yBFqC7k63fwNJOkmLhlYSsUVQ",0,"[{\"data\":{\"value\":[]},\"keyPath\":[\"syncMap\",\"applicationFonts\",\"6\"],\"state\":{\"hashValue\":\"00000000\"}},{\"data\":{\"value\":[]},\"keyPath\":[\"syncMap\",\"domainFonts\",\"0\"],\"state\":{\"hashValue\":\"00000000\"}},{\"data\":{\"familyList\":[\"Alegreya\",\"Amatic SC\",\"Bree Serif\",\"Calibri\",\"Cambria\",\"Merriweather\",\"Permanent Marker\",\"Pinyon Script\",\"Playfair Display\",\"Proxima Nova\",\"Roboto\",\"Roboto Mono\",\"Ultra\",\"Varela Round\"],\"recentlyUsedFamilyList\":[],\"transitionedFamilyList\":[],\"hasTransitioned\":true},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-fonts\"],\"state\":{\"timestamp\":1772903438837428}},{\"data\":{\"value\":true},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-dlpc\"],\"state\":{\"timestamp\":1772903438840462}},{\"data\":{\"value\":false},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-mention-dsp\"],\"state\":{\"timestamp\":1772903438842058}},{\"data\":{\"value\":true},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-enable_colon_emoji_insertion\"],\"state\":{\"timestamp\":1772903438842058}},{\"data\":{\"value\":false},\"keyPath\":[\"syncMap\",\"preferences\",\"mae-show_addons_menu_promo\"],\"state\":{\"timestamp\":1772903438843630}},{\"data\":{\"value\":false},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-homescreen-aips\"],\"state\":{\"timestamp\":1772903438845784}},{\"data\":{},\"keyPath\":[\"syncMap\",\"preferences\",\"docs-homescreen-asp\",\"6\"],\"state\":{\"timestamp\":1733368122745441}},{\"data\":{\"value